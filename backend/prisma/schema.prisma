generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  nama       String
  email      String   @unique
  password   String
  role                   String    @default("teknisi") // admin | teknisi
  reset_password_token   String?   @db.VarChar(255)
  reset_password_expires DateTime?
  created_at             DateTime  @default(now())

  tiket_servis TiketServis[] @relation("TeknisiTiket")
  activity_logs ActivityLog[]
}

model Customer {
  id            Int      @id @default(autoincrement())
  nama          String
  nomor_telepon String
  alamat        String?
  created_at    DateTime @default(now())

  perangkat Perangkat[]
}

model Perangkat {
  id              Int      @id @default(autoincrement())
  customer_id     Int
  jenis_perangkat String
  merek           String
  model           String
  serial_number   String?
  created_at      DateTime @default(now())

  customer     Customer     @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  tiket_servis TiketServis[]
}

model TiketServis {
  id             Int      @id @default(autoincrement())
  nomor_tiket    String   @unique
  perangkat_id   Int
  teknisi_id     Int?
  keluhan        String   @db.Text
  kelengkapan    String?  @db.Text
  foto_kondisi   Json?
  status         String   @default("diterima") // diterima, didiagnosis, menunggu_persetujuan, disetujui, dalam_perbaikan, selesai, diambil, dibatalkan
  created_at     DateTime @default(now())

  perangkat         Perangkat          @relation(fields: [perangkat_id], references: [id], onDelete: Cascade)
  teknisi           User?              @relation("TeknisiTiket", fields: [teknisi_id], references: [id], onDelete: SetNull)
  diagnosis         Diagnosis?
  log_perbaikan     LogPerbaikan[]
  penggunaan_sparepart PenggunaanSparepart[]
  invoice           Invoice?
}

model Diagnosis {
  id              Int      @id @default(autoincrement())
  tiket_id        Int      @unique
  masalah         String
  solusi          String
  estimasi_biaya  Float
  created_at      DateTime @default(now())

  tiket TiketServis @relation(fields: [tiket_id], references: [id], onDelete: Cascade)
}

model LogPerbaikan {
  id         Int      @id @default(autoincrement())
  tiket_id   Int
  fase       String   @default("Diagnosis")
  catatan    String
  foto_url   String?  @db.LongText
  created_at DateTime @default(now())

  tiket TiketServis @relation(fields: [tiket_id], references: [id], onDelete: Cascade)
}

model Brand {
  id         Int      @id @default(autoincrement())
  nama       String   @unique
  created_at DateTime @default(now())

  spareparts Sparepart[]
}

model Sparepart {
  id         Int      @id @default(autoincrement())
  brand_id   Int?
  kategori   String   @default("Umum") // Laptop, Desktop, Printer, Umum
  nama       String
  stok       Int      @default(0)
  harga      Float
  created_at DateTime @default(now())

  brand      Brand?   @relation(fields: [brand_id], references: [id], onDelete: Restrict)
  penggunaan_sparepart PenggunaanSparepart[]
}

model PenggunaanSparepart {
  id           Int @id @default(autoincrement())
  tiket_id     Int
  sparepart_id Int
  jumlah       Int

  tiket     TiketServis @relation(fields: [tiket_id], references: [id], onDelete: Cascade)
  sparepart Sparepart   @relation(fields: [sparepart_id], references: [id], onDelete: Cascade)

  @@unique([tiket_id, sparepart_id])
}

model Invoice {
  id              Int      @id @default(autoincrement())
  tiket_id        Int      @unique
  biaya_jasa      Float
  biaya_sparepart Float
  total_biaya     Float
  created_at      DateTime @default(now())

  tiket TiketServis @relation(fields: [tiket_id], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  user_nama  String
  action     String
  entity     String?
  created_at DateTime @default(now())

  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
}
